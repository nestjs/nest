{
  "compilerOptions": {
    "module": "nodenext",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "types": [
      "vitest/globals"
    ],
    "rootDir": "./src",
    "useDefineForClassFields": false,
    "strictPropertyInitialization": false
  },
  "include": [
    "src/**/*"
  ]
}
