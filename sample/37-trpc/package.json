{
  "name": "nest-trpc-sample",
  "version": "1.0.0",
  "description": "Nest tRPC sample application",
  "license": "MIT",
  "scripts": {
    "prepare:local-trpc": "node ./scripts/prepare-local-trpc.cjs",
    "generate:types": "ts-node --transpile-only src/generate-types.ts",
    "prebuild": "npm run prepare:local-trpc && rimraf dist src/@generated",
    "build": "npm run generate:types && nest build",
    "typecheck": "npm run generate:types && tsc --noEmit -p tsconfig.json",
    "typecheck:client": "npm run generate:types && tsc --noEmit -p tsconfig.client.json",
    "test": "npm run typecheck:client",
    "test:e2e": "npm run typecheck:client",
    "prestart": "npm run prepare:local-trpc && npm run generate:types",
    "start": "nest start",
    "start:dev": "npm run prepare:local-trpc && npm run generate:types && nest start --watch",
    "start:fastify": "npm run prepare:local-trpc && npm run generate:types && ts-node src/main-fastify.ts",
    "preclient": "npm run prepare:local-trpc && npm run generate:types",
    "client": "ts-node src/client.ts",
    "preclient:subscription": "npm run prepare:local-trpc && npm run generate:types",
    "client:subscription": "ts-node src/subscription-client.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.16",
    "@nestjs/core": "11.1.16",
    "@nestjs/platform-express": "11.1.16",
    "@nestjs/platform-fastify": "11.1.16",
    "@nestjs/trpc": "file:../../packages/trpc",
    "@trpc/client": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "eventsource": "4.1.0",
    "fastify": "5.8.2",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.16",
    "@types/node": "24.12.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
