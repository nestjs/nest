{
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "noImplicitAny": false,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "target": "ES2021",
        "sourceMap": false,
        "outDir": "./dist",
        "rootDir": "./src",
        "skipLibCheck": true,
        "strict": true,
        "strictPropertyInitialization": false,
        "paths": {
            "@nestjs/common": [
                "../../packages/common"
            ],
            "@nestjs/common/*": [
                "../../packages/common/*"
            ],
            "@nestjs/core": [
                "../../packages/core"
            ],
            "@nestjs/core/*": [
                "../../packages/core/*"
            ],
            "@nestjs/trpc": [
                "../../packages/trpc"
            ],
            "@nestjs/trpc/*": [
                "../../packages/trpc/*"
            ],
            "@nestjs/testing": [
                "../../packages/testing"
            ],
            "@nestjs/testing/*": [
                "../../packages/testing/*"
            ],
            "@nestjs/platform-express": [
                "../../packages/platform-express"
            ],
            "@nestjs/platform-express/*": [
                "../../packages/platform-express/*"
            ]
        }
    }
}